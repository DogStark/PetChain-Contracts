# PetChain Environment Configuration
# Copy this file to .env and fill in the values

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ADDRESS=your_contract_address_here

# 2FA Configuration
JWT_SECRET=your_jwt_secret_here
TOTP_ISSUER=PetChain

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/petchain

# Secret provider selection: 'env' (default) or 'aws'
SECRET_PROVIDER=env

# When using AWS Secrets Manager in testing, set a JSON map of secrets:
# AWS_SECRETS_JSON='{"DATABASE_URL": "postgresql://user:pass@host:5432/db"}'